[
  {
    "id": "panNumber",
    "type": "text",
    "label": "PAN Number",
    "required": true,
    "section": "personal",
    "pattern": "^[A-Z]{5}[0-9]{4}[A-Z]$",
    "errorMessage": "Enter a valid 10-digit PAN (e.g., ABCDE1234F)",
    "maxLength": 10
  },
  {
    "id": "assessmentYear",
    "type": "select",
    "label": "Assessment Year",
    "required": true,
    "section": "personal",
    "options": [
      { "value": "2025-26", "label": "2025-26" },
      { "value": "2024-25", "label": "2024-25" }
    ]
  },
  {
    "id": "fullName",
    "type": "text",
    "label": "Full Name",
    "required": true,
    "section": "personal"
  },
  {
    "id": "aadhaarNumber",
    "type": "text",
    "label": "Aadhaar Number (optional)",
    "section": "personal",
    "pattern": "^[0-9]{12}$",
    "maxLength": 12
  },
  {
    "id": "filingType",
    "type": "radio",
    "label": "Filing Type",
    "required": true,
    "section": "personal",
    "options": [
      { "value": "individual", "label": "Individual" },
      { "value": "huf", "label": "HUF" }
    ]
  },
  {
    "id": "residentialStatus",
    "type": "select",
    "label": "Residential Status",
    "required": true,
    "section": "personal",
    "options": [
      { "value": "resident", "label": "Resident" },
      { "value": "nri", "label": "Non-Resident (NRI)" },
      { "value": "rnor", "label": "Resident but Not Ordinarily Resident" }
    ]
  },
  {
    "id": "haveSalary",
    "type": "radio",
    "label": "Do you have salary income?",
    "required": true,
    "section": "income",
    "options": [
      { "value": "yes", "label": "Yes" },
      { "value": "no", "label": "No" }
    ]
  },
  {
    "id": "salaryIncome",
    "type": "number",
    "label": "Gross Salary Income (₹)",
    "section": "income",
    "min": 0,
    "dependsOn": { "field": "haveSalary", "value": "yes" },
    "helpText": "Enter gross salary before deductions"
  },
  {
    "id": "haveHouseProperty",
    "type": "radio",
    "label": "Do you have income from house property?",
    "required": true,
    "section": "income",
    "options": [
      { "value": "yes", "label": "Yes" },
      { "value": "no", "label": "No" }
    ]
  },
  {
    "id": "rentalIncome",
    "type": "number",
    "label": "Rental Income (₹)",
    "section": "income",
    "min": 0,
    "dependsOn": { "field": "haveHouseProperty", "value": "yes" }
  },
  {
    "id": "haveBusinessIncome",
    "type": "radio",
    "label": "Do you have business/profession income?",
    "required": true,
    "section": "income",
    "options": [
      { "value": "yes", "label": "Yes" },
      { "value": "no", "label": "No" }
    ]
  },
  {
    "id": "haveCapitalGains",
    "type": "radio",
    "label": "Do you have capital gains?",
    "required": true,
    "section": "income",
    "options": [
      { "value": "yes", "label": "Yes" },
      { "value": "no", "label": "No" }
    ]
  },
  {
    "id": "section80C",
    "type": "number",
    "label": "Section 80C Deductions (₹)",
    "section": "deductions",
    "min": 0,
    "max": 150000,
    "helpText": "PPF, ELSS, life insurance, etc. Max ₹1,50,000"
  },
  {
    "id": "section80D",
    "type": "number",
    "label": "Section 80D - Health Insurance Premium (₹)",
    "section": "deductions",
    "min": 0,
    "max": 50000
  },
  {
    "id": "section24",
    "type": "number",
    "label": "Section 24 - Home Loan Interest (₹)",
    "section": "deductions",
    "min": 0
  },
  {
    "id": "tdsClaimed",
    "type": "number",
    "label": "TDS Already Deducted (₹)",
    "section": "taxes",
    "min": 0
  },
  {
    "id": "advanceTax",
    "type": "number",
    "label": "Advance Tax Paid (₹)",
    "section": "taxes",
    "min": 0
  },
  {
    "id": "bankAccountNumber",
    "type": "text",
    "label": "Bank Account Number (for refund)",
    "required": true,
    "section": "banking"
  },
  {
    "id": "ifscCode",
    "type": "text",
    "label": "IFSC Code",
    "required": true,
    "section": "banking",
    "pattern": "^[A-Z]{4}0[A-Z0-9]{6}$",
    "errorMessage": "Enter a valid IFSC code"
  }
]
