[
  {
    "id": "fullName",
    "type": "text",
    "label": "Full Name",
    "required": true,
    "section": "personal"
  },
  {
    "id": "dob",
    "type": "date",
    "label": "Date of Birth",
    "required": true,
    "section": "personal"
  },
  {
    "id": "gender",
    "type": "radio",
    "label": "Gender",
    "required": true,
    "section": "personal",
    "options": [
      { "value": "male", "label": "Male" },
      { "value": "female", "label": "Female" },
      { "value": "other", "label": "Other" }
    ]
  },
  {
    "id": "nationality",
    "type": "text",
    "label": "Nationality",
    "required": true,
    "section": "personal"
  },
  {
    "id": "email",
    "type": "email",
    "label": "Email Address",
    "required": true,
    "section": "contact"
  },
  {
    "id": "phone",
    "type": "tel",
    "label": "Phone Number",
    "required": true,
    "section": "contact"
  },
  {
    "id": "address",
    "type": "textarea",
    "label": "Correspondence Address",
    "required": true,
    "section": "contact"
  },
  {
    "id": "qualification",
    "type": "select",
    "label": "Highest Qualification",
    "required": true,
    "section": "academic",
    "options": [
      { "value": "10th", "label": "10th / Secondary" },
      { "value": "12th", "label": "12th / Higher Secondary" },
      { "value": "bachelor", "label": "Bachelor's Degree" },
      { "value": "master", "label": "Master's Degree" },
      { "value": "phd", "label": "PhD / Doctorate" },
      { "value": "diploma", "label": "Diploma" }
    ]
  },
  {
    "id": "lastInstitution",
    "type": "text",
    "label": "Last Attended Institution Name",
    "section": "academic"
  },
  {
    "id": "lastScore",
    "type": "number",
    "label": "Last Exam Score / Percentage",
    "section": "academic",
    "min": 0,
    "max": 100
  },
  {
    "id": "intendedCourse",
    "type": "text",
    "label": "Applying for Course / Program",
    "required": true,
    "section": "course"
  },
  {
    "id": "intendedInstitution",
    "type": "text",
    "label": "Institution Applying To",
    "required": true,
    "section": "course"
  },
  {
    "id": "studyLevel",
    "type": "select",
    "label": "Level of Study Sought",
    "required": true,
    "section": "course",
    "options": [
      { "value": "undergraduate", "label": "Undergraduate" },
      { "value": "postgraduate", "label": "Postgraduate" },
      { "value": "phd", "label": "PhD / Research" },
      { "value": "diploma", "label": "Diploma / Certificate" },
      { "value": "exchange", "label": "Exchange Program" }
    ]
  },
  {
    "id": "scholarshipType",
    "type": "select",
    "label": "Scholarship Type",
    "required": true,
    "section": "scholarship",
    "options": [
      { "value": "merit", "label": "Merit-Based" },
      { "value": "need", "label": "Need-Based" },
      { "value": "sports", "label": "Sports" },
      { "value": "research", "label": "Research" },
      { "value": "minority", "label": "Minority Scholarship" },
      { "value": "international", "label": "International Student" }
    ]
  },
  {
    "id": "familyIncome",
    "type": "number",
    "label": "Annual Family Income (₹ / USD)",
    "required": true,
    "section": "financial",
    "min": 0
  },
  {
    "id": "requireAccommodation",
    "type": "radio",
    "label": "Do you require hostel/accommodation?",
    "section": "financial",
    "options": [
      { "value": "yes", "label": "Yes" },
      { "value": "no", "label": "No" }
    ]
  },
  {
    "id": "essay",
    "type": "textarea",
    "label": "Statement of Purpose / Essay",
    "section": "documents",
    "helpText": "Describe why you deserve this scholarship and your future goals."
  },
  {
    "id": "declaration",
    "type": "checkbox",
    "label": "I declare that all information provided is true and complete",
    "required": true,
    "section": "declaration"
  }
]
